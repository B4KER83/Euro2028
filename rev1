<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>EURO 2028</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: #0d1117;
  font-family: 'Arial Narrow', Arial, sans-serif;
  overflow-x: hidden; overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  user-select: none; -webkit-user-select: none;
}
.page-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}
.pg-head {
  background: linear-gradient(135deg,#061730,#124094,#061730);
  border-bottom: 2px solid #00f2fe;
  padding: 7px 8px 5px;
  position: sticky; top: 0; z-index: 99;
  display: flex; align-items: center; justify-content: space-between; gap: 6px;
  width: 100%;
}
.pg-head-text h1 { color: #00f2fe; font-size: 13px; font-weight: 900; letter-spacing: 2px; }
.pg-head-text p  { color: #7a9acc; font-size: 7.5px; letter-spacing: 1px; margin-top: 1px; }
.btn-group { display: flex; gap: 6px; flex-shrink: 0; }
.hbtn {
  border: none; border-radius: 7px;
  font-size: 11px; font-weight: 900; padding: 7px 11px; cursor: pointer;
  white-space: nowrap; -webkit-tap-highlight-color: transparent;
}
.hbtn:active { opacity: .7; }
.btn-auto   { background: #00f2fe; color: #000; }
.btn-manual { background: #21262d; color: #00f2fe; border: 1px solid #00f2fe !important; }

.sec {
  background: #161b22; color: #00f2fe;
  font-size: 8.5px; font-weight: 900; letter-spacing: 2px;
  text-transform: uppercase; text-align: center; padding: 5px 4px;
  border-top: 1px solid #21262d; border-bottom: 1px solid #21262d;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%;
}
.sec::before,.sec::after { content:''; flex:1; height:1px; background:linear-gradient(to right,transparent,#00f2fe44); }
.sec::after { background:linear-gradient(to left,transparent,#00f2fe44); }

.legend {
  display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
  padding: 4px 6px; background: #0d1117;
  font-size: 7.5px; color: #6e7681; border-bottom: 1px solid #21262d;
  width: 100%;
}
.legend span { display: flex; align-items: center; gap: 3px; }
.ldot { width: 8px; height: 8px; border-radius: 2px; }

.content-section { width: 100%; max-width: 1600px; padding: 0 8px; }

.grp-band {
  display: flex; gap: 5px; padding: 6px 5px;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  background: #0d1117; scrollbar-width: none;
  justify-content: center; width: 100%;
}
.grp-band::-webkit-scrollbar { display: none; }

.grp { flex:0 0 auto; width:152px; border-radius:8px; overflow:hidden; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,.4); }
.grp-hdr { color:#fff; font-weight:900; font-size:10.5px; padding:4px 7px; display:flex; justify-content:space-between; align-items:center; }
.grp-tbl { width:100%; border-collapse:collapse; }
.grp-tbl th { background:#e8e8e8; font-size:7.5px; padding:2px; text-align:center; color:#555; }
.grp-tbl td { padding:2px; border-bottom:1px solid #eee; vertical-align:middle; }
.grp-tbl tr:last-child td { border-bottom:none; }
.tn { display:flex; align-items:center; gap:2px; font-weight:700; white-space:nowrap; font-size:8.5px; }
.fl { font-size:11px; line-height:1; }
.pts-c { font-weight:900; text-align:center; font-size:9px; }
.num-c { text-align:center; color:#777; font-size:8px; }
.q1{background:#c6f6d5!important} .q2{background:#bee3f8!important} .q3{background:#fefcbf!important}

.mrow { display:flex; align-items:center; padding:1.5px 4px; border-bottom:1px solid #f0f0f0; background:#f9f9f9; }
.mrow:last-child{border-bottom:none}
.mrow .md  { color:#bbb; font-size:7px; min-width:26px; flex-shrink:0; }
.mrow .mt1 { flex:1; font-weight:600; font-size:7.5px; white-space:nowrap; overflow:hidden; }
.mrow .mt2 { flex:1; text-align:right; font-weight:600; font-size:7.5px; white-space:nowrap; overflow:hidden; }
.mscore { background:#1a1a2e; color:#fff; padding:0 3px; border-radius:3px; font-weight:900; font-size:8px; margin:0 2px; flex-shrink:0; }

.ko-section { background:#0d1117; padding:0 5px 6px; width:100%; display:flex; flex-direction:column; align-items:center; }
.round-label { text-align:center; color:#00f2fe; font-size:8px; font-weight:900; letter-spacing:2px; text-transform:uppercase; padding:5px 0 3px; }
.ko-scroll { overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none; padding-bottom:2px; display:flex; justify-content:center; width:100%; }
.ko-scroll::-webkit-scrollbar{display:none}
.ko-row { display:flex; gap:5px; min-width:max-content; padding:0 1px; }

.mc { width:132px; flex-shrink:0; border:1.5px solid #21262d; border-radius:7px; overflow:hidden; background:#161b22; }
.mc .tr { display:flex; align-items:center; padding:4px 6px; border-bottom:1px solid #21262d; font-size:8px; font-weight:700; color:#e6edf3; white-space:nowrap; overflow:hidden; }
.mc .tr:last-of-type{border-bottom:none}
.mc .tr .sc { margin-left:auto; background:#21262d; color:#8b949e; padding:1px 4px; border-radius:4px; font-size:8px; min-width:16px; text-align:center; flex-shrink:0; font-weight:900; }
.mc .bi { background:#0d1117; font-size:7px; color:#6e7681; padding:2px 5px; text-align:center; }

.mc-final { width:160px; flex-shrink:0; border:2.5px solid #00f2fe; border-radius:9px; overflow:hidden; background:#0d1117; box-shadow:0 3px 12px rgba(0,242,254,.25); }
.mc-final .fh { background:linear-gradient(135deg,#0052d4,#4364f7,#6fb1fc); color:#fff; text-align:center; font-weight:900; font-size:11px; padding:5px; letter-spacing:2px; }
.mc-final .tr { display:flex; align-items:center; padding:5px 8px; border-bottom:1px solid #21262d; font-size:9.5px; font-weight:900; color:#e6edf3; }
.mc-final .tr:last-of-type{border-bottom:none}
.mc-final .tr .sc { margin-left:auto; background:#21262d; color:#6e7681; padding:2px 6px; border-radius:4px; font-size:9px; min-width:18px; text-align:center; }
.mc-final .bi { background:#161b22; font-size:7.5px; color:#8b949e; padding:3px 6px; text-align:center; }

.finals-row { display:flex; gap:8px; justify-content:center; align-items:flex-start; padding:2px 4px; flex-wrap:wrap; }
.pg-foot { background:#051124; color:#00f2fe; text-align:center; font-size:10px; font-weight:900; padding:8px; letter-spacing:2px; border-top:2px solid #00f2fe; margin-top:4px; width:100%; }

@media (min-width: 768px) {
  .page-wrapper { padding: 0 20px; }
  .pg-head { margin: 0 -20px; padding-left: 28px; padding-right: 28px; }
  .legend { margin: 0 -20px; padding: 8px 12px; width: calc(100% + 40px); }
  .sec { margin: 0 -20px; width: calc(100% + 40px); font-size: 12px; padding: 8px; }
  .content-section { max-width: 1400px; padding: 0; }
  .pg-head-text h1 { font-size: 20px; letter-spacing: 3px; }
  .pg-head-text p  { font-size: 11px; }
  .hbtn { font-size: 14px; padding: 9px 18px; }
  .ldot { width: 12px; height: 12px; }
  .grp-band { gap: 8px; padding: 10px 12px; }
  .grp { width: 220px; }
  .grp-hdr { font-size: 14px; padding: 6px 10px; }
  .grp-tbl th { font-size: 11px; padding: 3px 4px; }
  .grp-tbl td { padding: 3px 4px; }
  .tn { font-size: 12px; gap: 4px; }
  .fl { font-size: 15px; }
  .pts-c { font-size: 13px; }
  .num-c { font-size: 11px; }
  .mrow { padding: 3px 6px; }
  .mrow .md  { font-size: 10px; min-width: 36px; }
  .mrow .mt1, .mrow .mt2 { font-size: 11px; }
  .mscore { font-size: 11px; padding: 1px 5px; border-radius: 4px; }
  .ko-section { padding: 0 12px 10px; }
  .round-label { font-size: 12px; padding: 8px 0 5px; letter-spacing: 3px; }
  .ko-row { gap: 8px; }
  .mc { width: 190px; border-radius: 9px; }
  .mc .tr { font-size: 11.5px; padding: 5px 8px; }
  .mc .tr .sc { font-size: 11px; min-width: 22px; padding: 2px 6px; }
  .mc .bi { font-size: 10px; padding: 3px 8px; }
  .mc-final { width: 240px; border-radius: 12px; }
  .mc-final .fh { font-size: 16px; padding: 8px; letter-spacing: 3px; }
  .mc-final .tr { font-size: 13px; padding: 7px 12px; }
  .mc-final .tr .sc { font-size: 12px; min-width: 26px; padding: 3px 8px; }
  .mc-final .bi { font-size: 11px; padding: 4px 10px; }
  .pg-foot { font-size: 14px; padding: 12px; letter-spacing: 3px; }
}
@media (min-width: 1200px) {
  .content-section { max-width: 1600px; }
  .grp { width: 260px; }
  .mc { width: 210px; }
  .mc-final { width: 260px; }
}
</style>
</head>
<body>
<div class="page-wrapper">
  <div class="pg-head">
    <div class="pg-head-text">
      <h1>⚽ UEFA EURO 2028™</h1>
      <p>UK &amp; IRELAND &nbsp;|&nbsp; 09 JUN &ndash; 09 JUL 2028</p>
    </div>
    <div class="btn-group">
      <button class="hbtn btn-auto" id="auto-btn" onclick="fetchLiveScores()">⚡ Auto</button>
      <button class="hbtn btn-manual" onclick="alert('Manual update placeholder')">📝 Manual</button>
    </div>
  </div>

  <div class="legend">
    <span><div class="ldot" style="background:#c6f6d5;border:1px solid #68d391"></div>1st</span>
    <span><div class="ldot" style="background:#bee3f8;border:1px solid #63b3ed"></div>2nd</span>
    <span><div class="ldot" style="background:#fefcbf;border:1px solid #f6e05e"></div>3rd</span>
  </div>

  <div class="sec">GROUPS A &ndash; C</div>
  <div class="content-section"><div class="grp-band" id="top-groups"></div></div>
  
  <div class="sec">KNOCKOUT BRACKET</div>
  <div class="ko-section" id="ko"></div>
  
  <div class="sec">GROUPS D &ndash; F</div>
  <div class="content-section"><div class="grp-band" id="bot-groups"></div></div>
  <div class="pg-foot">UEFA EURO 2028™ &nbsp;&middot;&nbsp; FIXED TOURNAMENT BRACKET SCHEDULE</div>
</div>

<script>
var FLAGS = {};
var WORKER_URL = 'https://wc2026.tomfbaker.workers.dev';

var GROUPS = [
  { id:'A', hc:'linear-gradient(135deg,#1e3a8a,#3b82f6)', teams:['A1','A2','A3','A4'], matches:[] },
  { id:'B', hc:'linear-gradient(135deg,#b91c1c,#ef4444)', teams:['B1','B2','B3','B4'], matches:[] },
  { id:'C', hc:'linear-gradient(135deg,#15803d,#22c55e)', teams:['C1','C2','C3','C4'], matches:[] },
  { id:'D', hc:'linear-gradient(135deg,#6d28d9,#8b5cf6)', teams:['D1','D2','D3','D4'], matches:[] },
  { id:'E', hc:'linear-gradient(135deg,#b45309,#f59e0b)', teams:['E1','E2','E3','E4'], matches:[] },
  { id:'F', hc:'linear-gradient(135deg,#0f766e,#14b8a6)', teams:['F1','F2','F3','F4'], matches:[] }
];

// Euro Standard 24-team fixed match blueprint format
var KO = {
  r16: [
    {t1:'Winner Group B', t2:'3rd Group A/D/E/F', s1:null, s2:null, info:'Match 37 · 24 June 2028 · Wembley'},
    {t1:'Winner Group A', t2:'Runner-up Group C', s1:null, s2:null, info:'Match 38 · 24 June 2028 · Cardiff'},
    {t1:'Winner Group F', t2:'3rd Group A/B/C', s1:null, s2:null, info:'Match 39 · 25 June 2028 · Glasgow'},
    {t1:'Runner-up Group D', t2:'Runner-up Group E', s1:null, s2:null, info:'Match 40 · 25 June 2028 · Dublin'},
    {t1:'Winner Group E', t2:'3rd Group A/B/C/D', s1:null, s2:null, info:'Match 41 · 26 June 2028 · London'},
    {t1:'Winner Group D', t2:'Runner-up Group F', s1:null, s2:null, info:'Match 42 · 26 June 2028 · Manchester'},
    {t1:'Winner Group C', t2:'3rd Group D/E/F', s1:null, s2:null, info:'Match 43 · 27 June 2028 · Liverpool'},
    {t1:'Runner-up Group A', t2:'Runner-up Group B', s1:null, s2:null, info:'Match 44 · 27 June 2028 · Newcastle'}
  ],
  qf: [
    {t1:'Winner Match 39', t2:'Winner Match 37', s1:null, s2:null, info:'Match 45 · 02 July 2028 · Manchester'},
    {t1:'Winner Match 41', t2:'Winner Match 42', s1:null, s2:null, info:'Match 46 · 02 July 2028 · Dublin'},
    {t1:'Winner Match 43', t2:'Winner Match 44', s1:null, s2:null, info:'Match 47 · 03 July 2028 · Cardiff'},
    {t1:'Winner Match 40', t2:'Winner Match 38', s1:null, s2:null, info:'Match 48 · 03 July 2028 · London'}
  ],
  sf: [
    {t1:'Winner Match 45', t2:'Winner Match 46', s1:null, s2:null, info:'Match 49 · 06 July 2028 · Wembley'},
    {t1:'Winner Match 47', t2:'Winner Match 48', s1:null, s2:null, info:'Match 50 · 07 July 2028 · Birmingham'}
  ],
  final: {t1:'Winner Match 49', t2:'Winner Match 50', s1:null, s2:null, info:'Match 51 · 09 July 2028 · Wembley Stadium'}
};

function renderAll() {
  var topG = document.getElementById('top-groups');
  var botG = document.getElementById('bot-groups');
  topG.innerHTML = ''; botG.innerHTML = '';

  GROUPS.forEach(function(g, idx) {
    var html = '<div class="grp"><div class="grp-hdr" style="background:'+g.hc+'">Group '+g.id+'</div>';
    html += '<table class="grp-tbl"><tr><th>TEAM</th><th>GD</th><th>PTS</th></tr>';
    g.teams.forEach(function(team, rk) {
      var cls = rk === 0 ? 'q1' : (rk === 1 ? 'q2' : (rk === 2 ? 'q3' : ''));
      html += '<tr class="'+cls+'"><td class="tn">🏳️ '+team+'</td><td class="num-c">0</td><td class="pts-c">0</td></tr>';
    });
    html += '</table></div>';
    if(idx < 3) topG.innerHTML += html; else botG.innerHTML += html;
  });

  var koSection = document.getElementById('ko');
  koSection.innerHTML = '';

  ['r16', 'qf', 'sf'].forEach(function(roundKey) {
    var label = roundKey === 'r16' ? 'Round of 16' : (roundKey === 'qf' ? 'Quarter-Finals' : 'Semi-Finals');
    var roundHtml = '<div class="round-label">'+label+'</div><div class="ko-scroll"><div class="ko-row">';
    KO[roundKey].forEach(function(m) {
      roundHtml += '<div class="mc">' +
        '<div class="tr"><span>🔹 '+m.t1+'</span><span class="sc">-</span></div>' +
        '<div class="tr"><span>🔹 '+m.t2+'</span><span class="sc">-</span></div>' +
        '<div class="bi">'+m.info+'</div></div>';
    });
    roundHtml += '</div></div>';
    koSection.innerHTML += roundHtml;
  });

  koSection.innerHTML += '<div class="round-label">Final</div><div class="finals-row"><div class="mc-final">' +
    '<div class="fh">EURO 2028 FINAL</div>' +
    '<div class="tr"><span>🏆 '+KO.final.t1+'</span><span class="sc">-</span></div>' +
    '<div class="tr"><span>🏆 '+KO.final.t2+'</span><span class="sc">-</span></div>' +
    '<div class="bi">'+KO.final.info+'</div></div></div>';
}

function fetchLiveScores() {
  var btn = document.getElementById('auto-btn');
  btn.innerText = '⌛...';
  setTimeout(function() { btn.innerText = '⚡ Auto'; }, 1000);
}

renderAll();
</script>
</body>
</html>
